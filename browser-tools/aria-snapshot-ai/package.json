{
  "name": "aria-snapshot-ai",
  "packageManager": "yarn@4.10.3",
  "dependencies": {
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "esbuild": "^0.27.3",
    "typescript": "^5.9.3"
  },
  "scripts": {
    "build": "tsc",
    "bundle": "yarn esbuild bundle.js --bundle --outfile=../aria-snapshot-bundle.js --format=iife --target=es2020 --global-name=__ariaSnapshotBundle",
    "bundle:dev": "yarn esbuild src/ariaSnapshot.ts --bundle --outfile=../aria-snapshot-bundle.js --format=iife --target=es2020 --global-name=__ariaSnapshotBundle --sourcemap",
    "bundle:watch": "yarn esbuild src/ariaSnapshot.ts --bundle --outfile=../aria-snapshot-bundle.js --format=iife --target=es2020 --global-name=__ariaSnapshotBundle --sourcemap --watch"
  },
  "type": "module",
  "browser": "./bundle/aria-snapshot-ai.min.js",
  "types": "./dist/ariaSnapshot.d.ts",
  "files": [
    "dist",
    "bundle"
  ]
}
